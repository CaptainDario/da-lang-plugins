{
  "id": "da.default.general",
  "name": "MeCab Furigana",
  "version": "0.1.0",
  "runtime": "webview",
  "family": "browserPlugin",
  "kind": "general",
  "description": "Annotates visible Japanese text with furigana ruby tags using da.host.mecab (free, no capability declaration needed).",
  "author": "DaLang",
  "permissions": {
    "hosts": ["<all_urls>"],
    "capabilities": []
  },
  "settings": [
    { "key": "enabled", "type": "bool", "label": "Show furigana", "default": true }
  ]
}
