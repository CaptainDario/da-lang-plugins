{
  "id": "da.examples",
  "name": "DaLang Examples",
  "version": "0.1.0",
  "updateUrl": "https://raw.githubusercontent.com/CaptainDario/da-lang-plugins/main/packs/examples/index.json",
  "plugins": [
    {
      "id": "da.examples.text-selection",
      "name": "Text Selection",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "textSelection",
      "description": "Reference textSelection plugin — exercises all 5 settings types, live settings updates, selection/clear events, and trigger modes.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled",     "type": "bool",   "label": "Enable selection",        "default": true },
        { "key": "minLength",   "type": "int",    "label": "Minimum word length",     "default": 1, "min": 1, "max": 20 },
        { "key": "sensitivity", "type": "double", "label": "Selection sensitivity",   "default": 0.5, "min": 0.1, "max": 1.0 },
        { "key": "prefix",      "type": "string", "label": "Text prefix",             "default": "" },
        { "key": "trigger",     "type": "choice", "label": "Trigger on",              "options": ["mouseup", "selectionchange", "both"], "default": "mouseup" }
      ],
      "codeUrl": "plugins/text-selection/script.dap"
    },
    {
      "id": "da.examples.subtitle",
      "name": "Subtitle Example",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "subtitle",
      "description": "Reference subtitle plugin — demonstrates da.register('get'), da.emit('subtitles'), MutationObserver push, and language tagging.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled",  "type": "bool",   "label": "Enable subtitles", "default": true },
        { "key": "language", "type": "choice", "label": "Language",         "options": ["ja", "zh", "ko", "en"], "default": "ja" }
      ],
      "codeUrl": "plugins/subtitle/script.dap"
    },
    {
      "id": "da.examples.general",
      "name": "General Example",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Reference general plugin — demonstrates DOM modification, da.register for app-callable functions, and da.emit('log').",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "invertColors", "type": "bool",   "label": "Invert page colors",  "default": false },
        { "key": "fontSize",     "type": "int",    "label": "Base font size (px)", "default": 16, "min": 10, "max": 32 },
        { "key": "opacity",      "type": "double", "label": "Page opacity",        "default": 1.0, "min": 0.2, "max": 1.0 },
        { "key": "injectText",   "type": "string", "label": "Banner text",         "default": "" },
        { "key": "theme",        "type": "choice", "label": "Force theme",         "options": ["none", "light", "dark"], "default": "none" }
      ],
      "codeUrl": "plugins/general/script.dap"
    },
    {
      "id": "da.examples.speak-selection",
      "name": "Speak Selection",
      "version": "0.2.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Reference host-capability plugin — speaks the selected text from the OS selection menu and the page title from the plugins bar, both through da.host.tts. Logs da.host.tts.engines() on load.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "contextMenuItems": [
        { "id": "speak-selection", "label": "Speak selection" }
      ],
      "menuShortcuts": [
        { "id": "speak-title", "label": "Speak page title" }
      ],
      "settings": [
        { "key": "engine", "type": "string", "label": "TTS engine id (blank = default)", "default": "" }
      ],
      "codeUrl": "plugins/speak-selection/script.dap"
    },
    {
      "id": "da.examples.parse-selection",
      "name": "Parse Selection",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Reference host-capability plugin — tokenizes the current text selection through da.host.language.parse and shows each token's surface, reading, base form, and POS. Demonstrates the engine-less language capability.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled", "type": "bool", "label": "Show parse panel on selection", "default": true }
      ],
      "codeUrl": "plugins/parse-selection/script.dap"
    },
    {
      "id": "da.examples.settings",
      "name": "Settings",
      "version": "0.1.0",
      "runtime": "webview",
      "family": "browserPlugin",
      "kind": "general",
      "description": "Reference settings plugin — declares all five setting types (bool, int, double, string, choice) and applies each live via onSettingsChanged so the effect is immediately observable.",
      "author": "DaLang",
      "hosts": ["<all_urls>"],
      "settings": [
        { "key": "enabled",    "type": "bool",   "label": "Show top banner",     "default": true },
        { "key": "fontSize",   "type": "int",    "label": "Base font size (px)", "default": 16, "min": 8, "max": 32 },
        { "key": "opacity",    "type": "double", "label": "Page opacity",        "default": 1.0, "min": 0.1, "max": 1.0 },
        { "key": "bannerText", "type": "string", "label": "Footer banner text",  "default": "DaLang" },
        { "key": "theme",      "type": "choice", "label": "Force theme",         "options": ["none", "light", "dark"], "default": "none" }
      ],
      "codeUrl": "plugins/settings/script.dap"
    }
  ]
}
